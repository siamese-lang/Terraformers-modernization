# Frontend API base URL.
# Leave empty during local CRA development to use package.json proxy -> http://localhost:8080.
# Set only when the frontend is served without the CRA dev proxy.
REACT_APP_API_BASE_URL=

# Source reference used by the current upload-to-analysis bridge.
# This pass creates analysis jobs from a browser-selected image name; binary upload is implemented later.
REACT_APP_ANALYSIS_SOURCE_BUCKET=example-bucket
REACT_APP_ANALYSIS_SOURCE_PREFIX=uploads

# Cognito browser auth configuration. Use local .env.local for real values. Do not commit real IDs.
REACT_APP_AWS_REGION=
REACT_APP_COGNITO_USER_POOL_ID=
REACT_APP_COGNITO_USER_POOL_CLIENT_ID=
