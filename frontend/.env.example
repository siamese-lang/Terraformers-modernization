# Frontend API base URL.
# Leave empty during local CRA development to use package.json proxy -> http://localhost:8080.
# Set the deployed backend origin when the frontend is served as a static production bundle.
REACT_APP_API_BASE_URL=

# Cognito browser authentication.
# Real values belong in an environment-specific secret/variable source, not in this file.
REACT_APP_AWS_REGION=
REACT_APP_COGNITO_USER_POOL_ID=
REACT_APP_COGNITO_USER_POOL_CLIENT_ID=

# Upload and analysis identifiers are created by POST /api/upload.
# Do not configure client-side project IDs, source buckets, or source object keys.
