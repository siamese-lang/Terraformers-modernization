environment = "dev"
aws_region  = "ap-northeast-2"

adapter_switches = {
  # Keep all adapters disabled for local/stub validation.
  # Enable them only after AWS dependencies and IAM policies are ready.
  s3_reader_enabled              = false
  s3_writer_enabled              = false
  bedrock_provider_enabled       = false
  bedrock_embedding_enabled      = false
  opensearch_retriever_enabled   = false
  analysis_sqs_publisher_enabled = false
}

database_runtime = {
  datasource_url      = "<jdbc-datasource-url>"
  datasource_username = "<datasource-username>"
  datasource_password = "<datasource-password>"
}

cognito_runtime = {
  region              = "<aws-region>"
  user_pool_id        = "<cognito-user-pool-id>"
  user_pool_client_id = "<cognito-user-pool-client-id>"
  jwks_url            = "<cognito-jwks-url>"
}

object_storage_runtime = {
  upload_bucket_name = "<upload-bucket-name>"
  result_bucket_name = "<result-bucket-name>"
  result_key_prefix  = "analysis-results"
}

queue_runtime = {
  ai_log_queue_url        = "<ai-log-queue-url>"
  terraform_log_queue_url = "<terraform-log-queue-url>"
}

bedrock_runtime = {
  model_id           = "<bedrock-vision-model-id>"
  embedding_model_id = "<bedrock-embedding-model-id>"
  max_tokens         = 8192
}

opensearch_runtime = {
  endpoint           = "<opensearch-or-aoss-endpoint>"
  service_name       = "aoss"
  top_k              = 3
  index_name         = "<reference-index-name>"
  vector_field_name  = "<vector-field-name>"
  content_field_name = "<content-field-name>"
}
