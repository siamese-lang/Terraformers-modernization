environment = "dev"
aws_region  = "ap-northeast-2"
name_prefix = "terraformers"

frontend_bucket_name = "replace-with-unique-terraformers-frontend-bucket"
frontend_bucket_force_destroy = false
noncurrent_version_expiration_days = 30

# This value exists only after the backend Ingress is reconciled by AWS Load
# Balancer Controller and the internal ALB is verified healthy.
api_origin_load_balancer_arn = "arn:aws:elasticloadbalancing:ap-northeast-2:000000000000:loadbalancer/app/replace-internal-alb/replace-id"

aliases             = []
acm_certificate_arn = null
price_class         = "PriceClass_200"

tags = {
  Project     = "terraformers-modernization"
  Environment = "dev"
  ManagedBy   = "terraform"
  CostOwner   = "replace-with-owner"
}
