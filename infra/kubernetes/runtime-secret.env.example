# Example shape only. Copy to a private local file before use.
# Do not commit real values or generated Secret manifests.

SPRING_DATASOURCE_URL=jdbc:mariadb://database.example.internal:3306/terraformers
SPRING_DATASOURCE_USERNAME=terraformers_app
SPRING_DATASOURCE_PASSWORD=example-password-not-a-secret

COGNITO_REGION=ap-northeast-2
COGNITO_USER_POOL_ID=ap-northeast-2_examplepool
COGNITO_USER_POOL_CLIENT_ID=exampleclientid
COGNITO_JWKS_URL=https://cognito-idp.ap-northeast-2.amazonaws.com/ap-northeast-2_examplepool/.well-known/jwks.json

S3_BUCKET_NAME=terraformers-dev-uploads-example
ANALYSIS_RESULT_BUCKET_NAME=terraformers-dev-results-example

AI_LOG_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/example-account/terraformers-dev-ai-log
TERRAFORM_LOG_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/example-account/terraformers-dev-terraform-log

BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
OPENSEARCH_ENDPOINT=https://opensearch.example.internal
INDEX_NAME=terraformers-reference
VECTOR_FIELD_NAME=embedding
CONTENT_FIELD_NAME=content
